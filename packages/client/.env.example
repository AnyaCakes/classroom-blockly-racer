# Copy to .env.local for local development (Vite auto-loads .env.local,
# which is gitignored - never commit real values here).
#
# URL of the game server. Defaults to http://localhost:4000 if unset,
# which is correct for local dev against `npm run dev:server`.
# In production, set this to wherever the server is actually deployed
# (Render/Railway/Fly), e.g. https://classroom-racer-server.onrender.com
VITE_SERVER_URL=http://localhost:4000
