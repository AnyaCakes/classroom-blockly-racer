# Copy to .env for local development (gitignored - never commit real values).
# Render/Railway/Fly: set these as real environment variables in their
# dashboard/CLI instead of relying on a .env file in production.

# Port the server listens on. Render/Railway/Fly set this automatically -
# only needed locally, and only if you want something other than 4000.
PORT=4000

# Which origin is allowed to connect (CORS + Socket.io). Must exactly
# match where the client is actually served from, including protocol.
# Local dev: the Vite dev server's origin.
# Production: your GitHub Pages URL, e.g. https://username.github.io
CLIENT_ORIGIN=http://localhost:5173
